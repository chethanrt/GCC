# =========================
# Ignore All Themes
# =========================
wp-content/themes/*

# Allow Only Custom Theme
!wp-content/themes/twentyeleven-child/

# Allow Theme Files
!wp-content/themes/twentyeleven-child/**

# =========================
# Ignore Plugins
# =========================
wp-content/plugins/*

# Allow Custom Plugins (optional)
!wp-content/plugins/custom-plugin/
!wp-content/plugins/custom-plugin/**

